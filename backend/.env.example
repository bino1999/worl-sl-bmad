# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/test_bmad
DB_HOST=localhost
DB_PORT=5432
DB_NAME=test_bmad
DB_USER=postgres
DB_PASSWORD=your_password

# Application Configuration
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=24h

# Email Service Configuration
EMAIL_SERVICE=sendgrid  # or 'mailgun'
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@test-bmad.com
# OR Mailgun configuration:
# MAILGUN_API_KEY=your_mailgun_api_key
# MAILGUN_DOMAIN=mg.test-bmad.com

# CORS Configuration
CORS_ORIGIN=http://localhost:5173  # Vite dev server default port

# Rate Limiting
RATE_LIMIT_WINDOW=60000  # 1 minute in milliseconds
RATE_LIMIT_MAX_REQUESTS=5  # max requests per window

# Email Verification
EMAIL_VERIFICATION_EXPIRY=24  # hours
EMAIL_VERIFICATION_TOKEN_LENGTH=32  # bytes
