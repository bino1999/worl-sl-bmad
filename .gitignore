# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.venv/

# ─── Build Outputs ────────────────────────────────────────────────────────────
dist/
dist-ssr/
build/

# ─── Environment & Secrets (NEVER commit real .env files) ─────────────────────
.env
.env.local
.env.*.local
# .env.example is safe to commit — it contains no real secrets

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Test & Coverage ──────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── OS Files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.local
.cache/
